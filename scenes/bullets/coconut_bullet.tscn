[sub_resource type="GDScript" id="GDScript_coconut"]
script/source = "extends Node2D
var rot_angle: float = 0.0
func _process(delta: float):
	rot_angle += delta * 8.0
	queue_redraw()
func _draw():
	draw_set_transform(Vector2.ZERO, rot_angle)
	draw_circle(Vector2(0, 0), 3.5, Color(0.35, 0.22, 0.10))
	draw_circle(Vector2(0, 0), 2.8, Color(0.50, 0.33, 0.15))
	draw_circle(Vector2(-1.0, -1.0), 0.8, Color(0.90, 0.85, 0.75))
	draw_circle(Vector2(0.5, -1.2), 0.8, Color(0.90, 0.85, 0.75))
	draw_circle(Vector2(0.8, 0.6), 0.8, Color(0.90, 0.85, 0.75))
	draw_set_transform(Vector2.ZERO, 0)
"

