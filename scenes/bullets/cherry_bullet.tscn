[sub_resource type="GDScript" id="GDScript_cherry"]
script/source = "extends Node2D
var rot_angle: float = 0.0
func _process(delta: float):
	rot_angle += delta * 14.0
	queue_redraw()
func _draw():
	draw_set_transform(Vector2.ZERO, rot_angle)
	draw_circle(Vector2(-1.5, 0.0), 2.8, Color(0.85, 0.05, 0.12))
	draw_circle(Vector2(1.5, 0.0), 2.8, Color(0.85, 0.05, 0.12))
	draw_circle(Vector2(-2.0, -0.5), 1.0, Color(1.0, 0.4, 0.45, 0.6))
	draw_circle(Vector2(1.0, -0.5), 1.0, Color(1.0, 0.4, 0.45, 0.6))
	draw_line(Vector2(0.0, -2.5), Vector2(0.0, -5.0), Color(0.25, 0.60, 0.15), 1.0)
	draw_set_transform(Vector2.ZERO, 0)
"

