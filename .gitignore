# ============================================
# Godot 4+ .gitignore (oczyszczony)
# ============================================

# Godot 4+ specific
.godot/
.godot/

# Imported resources
*.translation
*.import

# Mono
.mono/
data_*/
mono_crash.*.json

# Build / export
export/
builds/
*.apk
*.aab
*.exe
*.zip

# System
.DS_Store
Thumbs.db
desktop.ini

# Editors & IDE
.vscode/
.idea/
*.swp
*~

# Logs
*.log

# Python (dla skryptów narzędziowych)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# AI / Agent tools (Claude, Cursor, etc.)
.claude/
.github/agents/
.github/prompts/
*agent*.md
*prompt*.md

# Tymczasowe pliki deweloperskie
@*.py
dashboard.html
screenshot*.png
screenshots/
